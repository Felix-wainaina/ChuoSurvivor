{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "backend/study_model.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/study_model.py"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/$1"
    }
  ]
}